# Django core
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Options: sqlite3 | postgresql
DATABASE_ENGINE=sqlite3
DATABASE_NAME=tutors_marketplace
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tutorsmarketplace.local

# Platform business settings
PLATFORM_COMMISSION_PERCENTAGE=15.0
TEACHER_WITHDRAWAL_MINIMUM_THRESHOLD=100.0

# Security (enable in production with HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# HSTS: set seconds > 0 only after HTTPS is confirmed on the production domain
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
# Behind a trusted HTTPS proxy that sends this header, e.g. name=HTTP_X_FORWARDED_PROTO value=https
SECURE_PROXY_SSL_HEADER_NAME=
SECURE_PROXY_SSL_HEADER_VALUE=https
